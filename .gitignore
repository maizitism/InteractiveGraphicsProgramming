# ============================================================
#  Interactive Graphics Programming — .gitignore
#  Stack: CMake + vcpkg (manifest mode) + MSVC/Ninja + VS Code
# ============================================================

# ---- Claude Code (local assistant config & notes) ----
.claude/
CLAUDE.md

# ---- Build output (regenerated by the CMake presets) ----
Assignments/out/
out/
build/
[Bb]uild/

# ---- CMake generated files ----
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
_deps/

# ---- vcpkg (manifest mode installs into the build tree) ----
vcpkg_installed/
.vcpkg-root

# ---- Compiler / linker artifacts (MSVC + generic) ----
*.obj
*.o
*.exe
*.dll
*.lib
*.a
*.pdb
*.ilk
*.exp
*.idb
*.res

# ---- Visual Studio (this project uses VS Code, not full VS) ----
.vs/
*.sln
*.slnx
*.vcxproj
*.vcxproj.*

# ---- VS Code (machine-specific caches only; shared config is kept) ----
.vscode/ipch/
.vscode/*.log
*.code-workspace

# ---- OS clutter ----
Thumbs.db
Desktop.ini
.DS_Store
